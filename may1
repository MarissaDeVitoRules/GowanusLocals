<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gowanus Locals — Brooklyn's Canal Community</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0d0d0d;
    --charcoal: #1a1a1a;
    --steel: #2c2c2c;
    --iron: #3d3d3d;
    --rust: #2E8B57;
    --rust-bright: #3aab6d;
    --rust-light: #52c47f;
    --amber: #2E8B57;
    --cream: #f0ead8;
    --cream-dark: #e0d8c2;
    --stone: #8a8278;
    --mist: #b5b0a8;
    --canal-blue: #3d6875;
    --canal-dark: #1e3d47;
    --water: #4a7d8e;
    --white: #faf8f4;
    --font: 'Montserrat', sans-serif;
    --border-light: rgba(240,234,216,0.1);
    --border-rust: rgba(46,139,87,0.4);
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--font); background: var(--black); color: var(--cream); overflow-x: hidden; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 2.5rem; height: 60px;
    background: rgba(13,13,13,0.96); backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-light);
  }
  .nav-logo { font-size: 1rem; font-weight: 900; letter-spacing: 0.14em; text-transform: uppercase; color: var(--cream); text-decoration: none; }
  .nav-logo span { color: var(--rust-bright); }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; align-items: center; }
  .nav-links a { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--stone); text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--cream); }
  .nav-cta { background: var(--rust) !important; color: var(--cream) !important; padding: 0.4rem 1rem; }
  .nav-cta:hover { background: var(--rust-bright) !important; }

  /* HERO */
  .hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; overflow: hidden; }
  .hero-bg {
    position: absolute; inset: 0;
    background-image: url('https://images.unsplash.com/photo-1568515045052-f9a854d70bfd?w=1800&q=80');
    background-size: cover; background-position: center 60%;
    filter: brightness(0.3) contrast(1.15) saturate(0.6);
  }
  .hero-gradient { position: absolute; inset: 0; background: linear-gradient(to top, rgba(13,13,13,1) 0%, rgba(13,13,13,0.55) 45%, rgba(13,13,13,0.05) 100%); }
  .hero-content { position: relative; z-index: 2; padding: 0 5rem 2.5rem; max-width: 980px; }
  .hero-label { display: inline-flex; align-items: center; gap: 10px; font-size: 0.63rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust-light); margin-bottom: 0.9rem; animation: fadeUp 0.6s 0.2s both; }
  .hero-label::before { content: ''; display: block; width: 36px; height: 1px; background: var(--rust); }
  .hero-title { font-size: clamp(3rem, 8vw, 7rem); font-weight: 900; line-height: 0.88; letter-spacing: -0.04em; text-transform: uppercase; color: var(--white); margin-bottom: 1rem; animation: fadeUp 0.7s 0.35s both; }
  .hero-title .accent { color: var(--rust-bright); display: block; }
  .hero-desc { font-size: 0.93rem; font-weight: 300; line-height: 1.85; color: var(--mist); max-width: 660px; margin-bottom: 2rem; animation: fadeUp 0.7s 0.5s both; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; animation: fadeUp 0.7s 0.62s both; }

  .btn-rust { background: var(--rust); color: var(--white); padding: 0.9rem 2.25rem; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: background 0.2s, transform 0.15s; display: inline-block; }
  .btn-rust:hover { background: var(--rust-bright); transform: translateY(-2px); }
  .btn-ghost { border: 1px solid rgba(240,234,216,0.3); color: var(--cream); padding: 0.9rem 2.25rem; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: border-color 0.2s, background 0.2s; display: inline-block; }
  .btn-ghost:hover { border-color: var(--cream); background: rgba(240,234,216,0.06); }

  .hero-stats { position: absolute; right: 4rem; bottom: 2.5rem; z-index: 2; display: flex; flex-direction: column; gap: 1.5rem; }
  .hstat { text-align: right; }
  .hstat-num { font-size: 2.5rem; font-weight: 900; letter-spacing: -0.04em; color: var(--white); display: block; line-height: 1; }
  .hstat-label { font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--stone); display: block; margin-top: 3px; }
  .hstat + .hstat { padding-top: 1.5rem; border-top: 1px solid var(--border-light); }

  /* TICKER */
  .ticker-wrap { background: var(--rust); padding: 0.65rem 0; overflow: hidden; white-space: nowrap; }
  .ticker-inner { display: inline-block; animation: ticker 32s linear infinite; }
  .ticker-inner span { font-size: 0.65rem; font-weight: 800; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.88); margin: 0 2.5rem; }
  .ticker-inner span::before { content: '◆'; margin-right: 2.5rem; opacity: 0.45; font-size: 0.45rem; vertical-align: middle; }
  @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* PHOTO STRIP */
  .photo-strip { display: grid; grid-template-columns: repeat(4, 1fr); height: 270px; gap: 2px; }
  .photo-panel { position: relative; overflow: hidden; cursor: pointer; }
  .photo-panel img { width: 100%; height: 100%; object-fit: cover; object-position: center; filter: brightness(0.5) saturate(0.55) contrast(1.1); transition: filter 0.4s, transform 0.5s; display: block; }
  .photo-panel:hover img { filter: brightness(0.65) saturate(0.75) contrast(1.05); transform: scale(1.04); }
  .photo-caption { position: absolute; bottom: 0; left: 0; right: 0; padding: 0.7rem 1rem; background: linear-gradient(to top, rgba(13,13,13,0.85), transparent); font-size: 0.58rem; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.55); }

  /* SHARED */
  .eyebrow { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; color: var(--rust-light); display: flex; align-items: center; gap: 10px; margin-bottom: 0.75rem; }
  .eyebrow::before { content: ''; display: block; width: 28px; height: 1px; background: var(--rust); }
  .section-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 900; letter-spacing: -0.035em; text-transform: uppercase; line-height: 0.92; color: var(--white); margin-bottom: 1rem; }
  .section-title span { color: var(--rust-bright); }
  .view-all { font-size: 0.63rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rust-light); text-decoration: none; display: flex; align-items: center; gap: 8px; transition: gap 0.2s, color 0.2s; }
  .view-all:hover { gap: 14px; color: var(--rust-bright); }

  /* EVENTS */
  .events-section { padding: 6rem 4rem; max-width: 1400px; margin: 0 auto; }
  .events-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); }
  .events-grid { display: grid; grid-template-columns: 1.8fr 1fr 1fr; gap: 2px; background: var(--iron); border: 1px solid var(--iron); }
  .event-card { background: var(--charcoal); padding: 2rem; cursor: pointer; text-decoration: none; color: inherit; display: block; transition: background 0.2s; }
  .event-card:hover { background: var(--steel); }
  .event-card.featured { grid-row: span 2; display: flex; flex-direction: column; justify-content: flex-end; min-height: 460px; position: relative; overflow: hidden; padding: 2.5rem; }
  .event-img { position: absolute; inset: 0; background: linear-gradient(135deg, var(--canal-dark), var(--black)); }
  .event-img img { width: 100%; height: 100%; object-fit: cover; object-position: center; filter: brightness(0.25) saturate(0.4); transition: filter 0.4s; display: block; }
  .event-card.featured:hover .event-img img { filter: brightness(0.35) saturate(0.5); }
  .event-card.featured > *:not(.event-img) { position: relative; z-index: 1; }
  .event-tag { display: inline-block; font-size: 0.58rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; padding: 0.25rem 0.6rem; margin-bottom: 1rem; border: 1px solid; }
  .tag-music { border-color: var(--rust); color: var(--rust-light); }
  .tag-art { border-color: var(--canal-blue); color: var(--water); }
  .tag-market { border-color: #4a7820; color: #7ab030; }
  .tag-history { border-color: var(--amber); color: var(--amber); }
  .tag-community { border-color: var(--mist); color: var(--mist); }
  .event-date { font-size: 0.63rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--stone); margin-bottom: 0.5rem; }
  .featured .event-date { color: rgba(255,255,255,0.38); }
  .event-title { font-size: 1rem; font-weight: 800; letter-spacing: -0.02em; text-transform: uppercase; line-height: 1.15; margin-bottom: 0.5rem; color: var(--cream); }
  .featured .event-title { font-size: 1.9rem; color: white; line-height: 1; }
  .event-venue { font-size: 0.73rem; font-weight: 300; color: var(--stone); }
  .featured .event-venue { color: rgba(255,255,255,0.4); }

  /* HISTORY */
  .history-section { padding: 7rem 4rem; position: relative; overflow: hidden; background: var(--charcoal); }
  .history-accent-line { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(to right, var(--rust), var(--canal-blue), transparent); }
  .history-inner { position: relative; z-index: 2; max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 7rem; align-items: start; }
  .history-intro { font-size: 0.88rem; font-weight: 300; line-height: 1.9; color: var(--mist); margin-top: 1.5rem; }
  .history-intro p { margin-bottom: 1.25rem; }
  .history-intro strong { color: var(--cream); font-weight: 600; }
  .history-intro a { color: var(--rust-light); text-decoration: none; border-bottom: 1px solid rgba(181,66,10,0.35); transition: color 0.2s; }
  .history-intro a:hover { color: var(--rust-bright); }
  .history-timeline { padding-top: 0.25rem; }
  .tl-item { display: grid; grid-template-columns: 90px 1fr; gap: 1.5rem; margin-bottom: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--border-light); }
  .tl-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .tl-year { font-size: 0.72rem; font-weight: 900; letter-spacing: 0.06em; color: var(--rust-bright); padding-top: 4px; border-top: 2px solid var(--rust); }
  .tl-text { font-size: 0.82rem; font-weight: 300; line-height: 1.75; color: var(--mist); }
  .tl-text strong { color: var(--cream); font-weight: 600; }
  .tl-text a { color: var(--rust-light); text-decoration: none; }
  .tl-text a:hover { color: var(--rust-bright); }

  /* ORGS */
  .orgs-section { background: var(--black); padding: 5rem 4rem; border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); }
  .orgs-inner { max-width: 1400px; margin: 0 auto; }
  .orgs-label { font-size: 0.6rem; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: var(--stone); margin-bottom: 2.5rem; display: flex; align-items: center; gap: 1.5rem; }
  .orgs-label::after { content: ''; flex: 1; height: 1px; background: var(--border-light); }
  .orgs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: var(--iron); }
  .org-card { background: var(--charcoal); padding: 2.25rem 2rem; text-decoration: none; color: inherit; transition: background 0.2s; display: block; border-left: 3px solid transparent; }
  .org-card:hover { background: var(--steel); }
  .org-card.c-rust { border-left-color: var(--rust); }
  .org-card.c-blue { border-left-color: var(--canal-blue); }
  .org-card.c-amber { border-left-color: var(--amber); }
  .org-name { font-size: 0.78rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; color: var(--white); margin-bottom: 0.6rem; display: block; }
  .org-desc { font-size: 0.78rem; font-weight: 300; line-height: 1.75; color: var(--stone); margin-bottom: 1rem; }
  .org-link { font-size: 0.58rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: var(--rust-light); }

  /* CANAL FULL */
  .canal-full { height: 500px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .canal-full img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 50%; filter: brightness(0.32) saturate(0.45) contrast(1.15); }
  .canal-full-text { position: relative; z-index: 2; text-align: center; padding: 2rem; }
  .canal-quote { font-size: clamp(1.6rem, 4.5vw, 4rem); font-weight: 900; font-style: italic; letter-spacing: -0.03em; text-transform: uppercase; color: white; line-height: 1.05; max-width: 1000px; }
  .canal-quote span { color: var(--rust-bright); }
  .canal-attribution { margin-top: 1.5rem; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255,255,255,0.35); }

  /* DIRECTORY */
  .directory-section { padding: 6rem 4rem; max-width: 1400px; margin: 0 auto; }
  .dir-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); }
  .cat-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; background: var(--iron); border: 1px solid var(--iron); }
  .cat-card { background: var(--charcoal); padding: 2rem 1.25rem; text-align: center; text-decoration: none; color: inherit; display: block; transition: background 0.2s; border-top: 3px solid transparent; }
  .cat-card:hover { background: var(--steel); border-top-color: var(--rust); }
  .cat-icon { font-size: 1.75rem; display: block; margin-bottom: 0.75rem; }
  .cat-name { font-size: 0.67rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream); display: block; margin-bottom: 0.3rem; }
  .cat-count { font-size: 0.6rem; font-weight: 500; letter-spacing: 0.08em; color: var(--stone); }

  /* DIRECTORY LISTINGS */
  .dir-group { margin-top: 3.5rem; }
  .dir-group-title { font-size: 0.72rem; font-weight: 900; letter-spacing: 0.18em; text-transform: uppercase; color: var(--rust-light); display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border-light); }
  .dir-group-title span { font-size: 1rem; }
  .biz-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: var(--iron); }
  .biz-card { background: var(--charcoal); padding: 1.5rem; transition: background 0.2s; }
  .biz-card:hover { background: var(--steel); }
  .biz-name { font-size: 0.88rem; font-weight: 800; letter-spacing: 0.02em; color: var(--white); margin-bottom: 0.2rem; text-transform: uppercase; }
  .biz-type { font-size: 0.6rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--rust-light); margin-bottom: 0.2rem; }
  .biz-address { font-size: 0.68rem; font-weight: 400; color: var(--stone); margin-bottom: 0.6rem; letter-spacing: 0.04em; }
  .biz-desc { font-size: 0.78rem; font-weight: 300; line-height: 1.7; color: var(--mist); }
  .biz-desc a { color: var(--rust-light); text-decoration: none; }
  .biz-desc a:hover { color: var(--rust-bright); }
  @media (max-width: 900px) { .biz-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .biz-grid { grid-template-columns: 1fr; } }
  .instagram-section { padding: 6rem 4rem; max-width: 1400px; margin: 0 auto; }
  .ig-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-light); }
  .ig-handle { font-size: 0.75rem; font-weight: 300; color: var(--stone); margin-top: 0.3rem; }
  .ig-embed-box { background: var(--charcoal); border: 1px solid var(--iron); padding: 3rem; text-align: center; }
  .ig-embed-title { font-size: 0.82rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream); margin-bottom: 0.5rem; }
  .ig-embed-sub { font-size: 0.75rem; font-weight: 300; color: var(--stone); margin-bottom: 2rem; }
  .ig-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; margin-bottom: 2rem; }
  .ig-ph { aspect-ratio: 1; background: var(--steel); opacity: 0.4; }
  .ig-ph:nth-child(2) { opacity: 0.55; }
  .ig-ph:nth-child(3) { opacity: 0.38; }
  .ig-ph:nth-child(4) { opacity: 0.28; }
  .ig-link { font-size: 0.68rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: var(--rust-light); text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: color 0.2s; }
  .ig-link:hover { color: var(--rust-bright); }

  /* CONTACT BAR */
  .contact-bar { background: var(--rust); padding: 1.1rem 4rem; }
  .contact-inner { max-width: 1400px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .contact-text { font-size: 0.78rem; font-weight: 500; color: rgba(255,255,255,0.9); letter-spacing: 0.02em; }
  .contact-link { color: white; font-weight: 800; text-decoration: none; border-bottom: 1px solid rgba(255,255,255,0.5); padding-bottom: 1px; transition: border-color 0.2s; }
  .contact-link:hover { border-color: white; }
  .contact-email { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.2s; }
  .contact-email:hover { color: white; }

  /* NEWSLETTER */
  .newsletter-section { background: var(--charcoal); border-top: 3px solid var(--rust); padding: 7rem 4rem; }
  .nl-inner { max-width: 660px; margin: 0 auto; text-align: center; }
  .nl-title { font-size: clamp(2.2rem, 5.5vw, 4rem); font-weight: 900; letter-spacing: -0.04em; text-transform: uppercase; line-height: 0.9; color: var(--white); margin-bottom: 1.25rem; }
  .nl-title span { color: var(--rust-bright); display: block; }
  .nl-desc { font-size: 0.87rem; font-weight: 300; line-height: 1.8; color: var(--stone); margin-bottom: 2.5rem; }
  .btn-substack { display: inline-flex; align-items: center; gap: 12px; background: var(--rust); color: white; padding: 1rem 2.5rem; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: background 0.2s, transform 0.15s; }
  .btn-substack:hover { background: var(--rust-bright); transform: translateY(-2px); }
  .substack-icon { width: 22px; height: 22px; background: white; color: var(--rust); border-radius: 50%; font-size: 0.75rem; font-weight: 900; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-style: normal; }
  .nl-fine { margin-top: 1rem; font-size: 0.65rem; font-weight: 400; letter-spacing: 0.08em; color: var(--iron); }

  /* FOOTER */
  footer { background: var(--black); padding: 5rem 4rem 2.5rem; border-top: 1px solid var(--border-light); }
  .footer-inner { max-width: 1400px; margin: 0 auto; }
  .footer-top { display: grid; grid-template-columns: 2.5fr 1fr 1fr 1fr; gap: 4rem; margin-bottom: 4rem; padding-bottom: 3rem; border-bottom: 1px solid var(--border-light); }
  .footer-logo { font-size: 1.1rem; font-weight: 900; letter-spacing: 0.14em; text-transform: uppercase; color: var(--white); text-decoration: none; display: block; margin-bottom: 1.25rem; }
  .footer-logo span { color: var(--rust-bright); }
  .footer-tagline { font-size: 0.8rem; font-weight: 300; line-height: 1.8; color: var(--stone); max-width: 280px; margin-bottom: 1.5rem; }
  .footer-org-links { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer-org-links a { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.04em; color: var(--stone); text-decoration: none; transition: color 0.2s; }
  .footer-org-links a:hover { color: var(--rust-light); }
  .footer-col-title { font-size: 0.58rem; font-weight: 900; letter-spacing: 0.2em; text-transform: uppercase; color: var(--rust); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 8px; }
  .footer-col-title::after { content: ''; flex: 1; height: 1px; background: var(--border-light); }
  .footer-links { list-style: none; }
  .footer-links li { margin-bottom: 0.7rem; }
  .footer-links a { font-size: 0.77rem; font-weight: 300; color: var(--stone); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--cream); }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--iron); }

  /* ANIMATIONS */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }

  /* RESPONSIVE */
  @media (max-width: 1100px) {
    .cat-grid { grid-template-columns: repeat(4, 1fr); }
    .events-grid { grid-template-columns: 1fr 1fr; }
    .event-card.featured { grid-row: span 1; min-height: 300px; }
    .history-inner { grid-template-columns: 1fr; gap: 4rem; }
    .footer-top { grid-template-columns: 1fr 1fr; gap: 3rem; }
    .orgs-grid { grid-template-columns: 1fr; }
    .photo-strip { grid-template-columns: repeat(2, 1fr); height: auto; }
    .photo-panel { height: 200px; }
    .hero-stats { display: none; }
  }
