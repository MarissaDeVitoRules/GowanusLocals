<script>
// ─────────────────────────────────────────────────────────────
// GOOGLE SHEETS EVENTS SYNC
// HOW TO SET UP:
// 1. Create a Google Sheet with these column headers in row 1:
//    title | date | venue | category | link | featured
// 2. File → Share → Publish to web → Sheet1 → CSV → Publish
// 3. Copy the URL and paste it below as SHEET_URL
// 4. Set featured = TRUE on one row to make it the big card
// ─────────────────────────────────────────────────────────────
const SHEET_URL = ''; // ← PASTE YOUR PUBLISHED CSV URL HERE

const TAG_CLASSES = {
  music: 'tag-music', art: 'tag-art', market: 'tag-market',
  history: 'tag-history', community: 'tag-community', food: 'tag-market'
};

async function loadEventsFromSheet() {
  if (!SHEET_URL) return; // No URL set yet — static HTML shows instead

  try {
    const res = await fetch(SHEET_URL);
    const csv = await res.text();
    const rows = csv.trim().split('\n').slice(1); // skip header row
    const events = rows.map(row => {
      const cols = row.split(',').map(c => c.replace(/^"|"$/g, '').trim());
      return { title: cols[0], date: cols[1], venue: cols[2], category: (cols[3]||'').toLowerCase(), link: cols[4], featured: cols[5] === 'TRUE' };
    }).filter(e => e.title);

    if (!events.length) return;

    const grid = document.querySelector('.events-grid');
    if (!grid) return;
    grid.innerHTML = '';

    const featured = events.find(e => e.featured) || events[0];
    const rest = events.filter(e => e !== featured).slice(0, 4);

    // Featured card
    const fc = document.createElement('a');
    fc.href = featured.link || '#';
    fc.className = 'event-card featured';
    fc.innerHTML = `
      <div class="event-img"><img src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=800&q=70" alt="Featured event"></div>
      <span class="event-tag ${TAG_CLASSES[featured.category] || 'tag-community'}">${featured.category || 'Event'}</span>
      <p class="event-date">${featured.date}</p>
      <h3 class="event-title">${featured.title}</h3>
      <p class="event-venue">${featured.venue}</p>`;
    grid.appendChild(fc);

    // Regular cards
    rest.forEach(ev => {
      const card = document.createElement('a');
      card.href = ev.link || '#';
      card.className = 'event-card';
      card.innerHTML = `
        <span class="event-tag ${TAG_CLASSES[ev.category] || 'tag-community'}">${ev.category || 'Event'}</span>
        <p class="event-date">${ev.date}</p>
        <h3 class="event-title">${ev.title}</h3>
        <p class="event-venue">${ev.venue}</p>`;
      grid.appendChild(card);
    });

  } catch (err) {
    console.log('Sheet sync failed, showing static events:', err);
  }
}

loadEventsFromSheet();
</script>
